# SuppCheckr environment variables (example only — copy to .env.local for local dev)
# Phase 7A: affiliate framework enabled; ads remain disabled.

# Site mode: development | staging | prelaunch | production
# Must remain prelaunch until intentional production launch.
SITE_MODE=prelaunch

# Public canonical URL (used in metadata, sitemap, Open Graph)
NEXT_PUBLIC_SITE_URL=https://suppcheckr.com

# Contact email shown on legal and contact pages
CONTACT_EMAIL=help@suppcheckr.com

# Amazon Associates tracking tag — set in deployment secrets after program approval.
# Leave unset/blank locally unless testing affiliate link generation.
# Production/Preview: configured as a Sensitive env var (never commit a real tag).
# AMAZON_ASSOCIATE_TAG=yourtag-20

# Monetization enable flags are in config/monetization.ts (not env vars):
#   affiliate.enabled          — true after Phase 7A activation
#   affiliate.disableGlobally  — false after Phase 7A activation
#   ads.enabled                — must stay false until ad approval
#   ads.loadScripts            — must stay false until ad approval
